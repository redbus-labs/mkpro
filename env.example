# Google Gemini (required for mkpro)
GOOGLE_API_KEY=your_gemini_api_key

# AWS Bedrock (optional - for Bedrock/Claude Opus models)
# Copy your Bedrock API key value here. Use with /config to select BEDROCK provider.
BEDROCK_URL=https://bedrock-runtime.ap-south-1.amazonaws.com/model
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_value

# Ollama (optional - for local models)
# OLLAMA_SERVER_URL=http://localhost:11434

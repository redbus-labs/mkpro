# Google Gemini (required for mkpro)
GOOGLE_API_KEY=your_gemini_api_key

# AWS Bedrock (optional - for Bedrock/Claude Opus models)
# Copy your Bedrock API key value here. Use with /config to select BEDROCK provider.
# Base URL only (no /model) - Converse path /model/{modelId}/converse is added by ADK
# Claude Opus 4.6: global.anthropic.claude-opus-4-6-v1 (access key from DevOps)
BEDROCK_URL=https://bedrock-runtime.ap-south-1.amazonaws.com
BEDROCK_API_KEY=your_fmis_key
# AWS_BEARER_TOKEN_BEDROCK=legacy_runtime_token

# Ollama (optional - for local models)
# OLLAMA_SERVER_URL=http://localhost:11434
